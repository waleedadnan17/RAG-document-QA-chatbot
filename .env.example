# OpenAI API Key (optional, for embeddings and LLM answering)
OPENAI_API_KEY=your_openai_api_key_here

# Model selection
# Options: gpt-3.5-turbo, gpt-4, etc.
LLM_MODEL=gpt-3.5-turbo

# Embedder configuration
# Options: openai, sentence-transformers, tfidf, auto
EMBEDDER_MODEL=auto

# Data directory for persisting FAISS index
DATA_DIR=data

# Chunk configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Retrieval settings
TOP_K=5

# LLM settings
TEMPERATURE=0.7
MAX_TOKENS=1000
